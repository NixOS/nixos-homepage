---
import { cva, type VariantProps } from 'class-variance-authority';

export const cardVariants = cva('w-full', {
  variants: {
    variant: {
      light: 'bg-secondary-afghani-blue-95',
      dark: 'bg-secondary-afghani-blue-35',
      outline: 'border-0.5 border-secondary-afghani-blue-15',
    },
    padding: {
      sm: 'px-4 py-3',
      md: 'p-4',
      lg: 'p-6',
    },
    rounded: {
      none: '',
      '2xl': 'rounded-2xl',
    },
  },
  defaultVariants: {
    variant: 'light',
    padding: 'md',
    rounded: '2xl',
  },
});

interface Props extends VariantProps<typeof cardVariants> {
  class?: string;
  tag?: string;
}

const {
  variant,
  padding,
  rounded,
  tag: Tag = 'div',
  class: extraClasses,
} = Astro.props;
---

<Tag class:list={[cardVariants({ variant, padding, rounded }), extraClasses]}>
  <slot />
</Tag>
