---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';

interface Props {
  sourceDarkMode: string | ImageMetadata;
  sourceLightMode: string | ImageMetadata;
  alt: string;
  class?: string;
}

const { sourceDarkMode, sourceLightMode, alt, class: className } = Astro.props;

const darkModeImg = await getImage({
  src: sourceDarkMode,
});

const lightModeImg = await getImage({
  src: sourceLightMode,
});
---

<picture>
  <source media="(prefers-color-scheme: dark)" srcset={darkModeImg.src} />
  <source media="(prefers-color-scheme: light)" srcset={lightModeImg.src} />
  <img src={lightModeImg.src} alt={alt} class={className} />
</picture>
