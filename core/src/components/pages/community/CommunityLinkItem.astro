---
import { Icon } from 'astro-icon/components';

interface Props {
  href: string;
  iconName?: string;
  name?: string;
  description?: string;
  type?: 'full' | 'mobile_icon_desktop_name' | 'icon';
  class?: string;
  variant?: 'official' | 'community';
}

const {
  href,
  iconName,
  name = '',
  description = '',
  type = 'full',
  class: extraClasses,
  variant = 'official',
} = Astro.props;

const effectiveType =
  !iconName && type === 'mobile_icon_desktop_name' ? 'full' : type;

const liClasses =
  variant === 'official'
    ? 'bg-secondary-afghani-blue-45 hover:bg-secondary-afghani-blue-35'
    : 'border-secondary-afghani-blue dark:border-secondary-afghani-blue-75 hover:bg-secondary-afghani-blue-95 dark:hover:bg-secondary-afghani-blue-25 border-2';

const aClasses =
  variant === 'official'
    ? 'text-primary-white no-underline!'
    : 'text-secondary-afghani-blue dark:text-secondary-afghani-blue-75 flex h-full flex-col no-underline!';
---

<li
  class:list={[
    'relative flex-1 cursor-pointer rounded-xl p-4 transition-all',
    liClasses,
    effectiveType === 'icon' && 'flex flex-col items-center justify-center',
    extraClasses,
  ]}
>
  <a href={href} class={aClasses}>
    <div
      class:list={[
        'flex gap-2 text-xl font-bold',
        (effectiveType !== 'full' || description === '') && 'h-full',
        effectiveType === 'mobile_icon_desktop_name' &&
          'flex-col items-center justify-center md:flex-row md:justify-start',
        !iconName && 'h-full items-center',
      ]}
    >
      {iconName && <Icon name={iconName} aria-hidden="true" class="h-8 w-8" />}
      {
        (effectiveType !== 'icon' || !iconName) && (
          <span
            class:list={[
              'leading-8',
              iconName ? 'ml-2' : 'text-center',
              effectiveType === 'mobile_icon_desktop_name' && iconName
                ? 'sr-only md:not-sr-only'
                : '',
            ]}
          >
            {name}
          </span>
        )
      }
    </div>
    {
      description !== '' && effectiveType === 'full' && (
        <div class="mt-2">{description}</div>
      )
    }
  </a>
</li>
