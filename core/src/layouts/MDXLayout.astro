---
import type { MarkdownLayoutProps } from 'astro';

import Container from '@nixos/ui/Container.astro';
import PageHeader from '@nixos/ui/PageHeader.astro';
import Layout from './Layout.astro';

type Props = MarkdownLayoutProps<{
  title: string;
  parentPath?: string;
}>;

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <PageHeader text={frontmatter.title} parentPath={frontmatter.parentPath} />
  <Container class="my-8">
    <article class="article">
      <slot />
    </article>
  </Container>
</Layout>
