---
import Container from '@nixos/ui/Container.astro';
import Headline from '@nixos/ui/Headline.astro';
import Paragraph from '@nixos/ui/Paragraph.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not Found">
  <Container class="my-16 space-y-4">
    <Headline variant="blue" level={1}>Not found</Headline>
    <Paragraph>
      The requested content<span id="signpost"></span> could not be found.
    </Paragraph>
    <script is:inline>
      document.getElementById('signpost').innerHTML =
        ` at <code>${window.location.pathname}</code>`;
    </script>
  </Container>
</Layout>
