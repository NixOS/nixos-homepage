---
import { getCollection, getEntry, render } from 'astro:content';
import { BANNER } from 'astro:env/client';
import Container from '../components/layout/Container.astro';
import Button from '../components/ui/Button.astro';
import NixosSearchInput from '../components/ui/NixosSearchInput.astro';
import Layout from '../layouts/Layout.astro';
import { generatePathFromPost } from '../lib/utils';

import Segment from '@/components/layout/Segment.astro';
import Headline from '@/components/ui/typography/Headline.astro';
import Paragraph from '@/components/ui/typography/Paragraph.astro';
import { Icon } from 'astro-icon/components';
import Asciinema from '../components/ui/Asciinema.astro';
import Banner from '../components/ui/Banner.astro';
import InlineSVG from '../components/util/InlineSVG.astro';

const landingFeatures = await getCollection('landingFeatures');
const demos = await getEntry('landing', 'demos');
const posts = await getCollection('blog');

const currentBanner = await getEntry('banners', BANNER);
const CurrentBannerContent = currentBanner
    ? (await render(currentBanner)).Content
    : undefined;

landingFeatures.sort((a, b) => a.id.localeCompare(b.id));

posts
    .sort((a, b) => {
        const dateA = new Date(a.data.date);
        const dateB = new Date(b.data.date);
        return dateA > dateB ? -1 : 1;
    })
    .filter((p) => {
        return p.id.split('/')?.[0] === 'announcements';
    })
    .reverse();
---

<Layout>
    {
        CurrentBannerContent ? (
            <CurrentBannerContent />
        ) : (
            <Banner
                wrapperClasses="bg-secondary-afghani-blue-95"
                class="font-heading text-secondary-afghani-blue-45 flex flex-col items-center justify-between gap-1 text-lg font-bold md:flex-row md:pt-8 md:pb-7"
            >
                <b>{posts[0].data.title}</b>
                <a
                    href={generatePathFromPost(posts[0])}
                    class="text-secondary-afghani-blue-45 hover:text-secondary-afghani-blue-75 inline-flex items-center gap-2"
                >
                    Read Announcement
                    <Icon name="mdi:arrow-right" />
                </a>
            </Banner>
        )
    }
    <Segment variant="blue-lambada">
        <Container
            class="grid grid-cols-1 gap-8 py-8 md:py-16 lg:grid-cols-2 lg:py-24"
        >
            <div
                class="mx-0 my-auto flex h-full flex-0 flex-col justify-between gap-3 md:gap-4 md:pr-12"
            >
                <Headline level={1} variant="white">
                    Declarative builds<br class="hidden md:inline-block" /> and deployments.
                </Headline>
                <Paragraph class="mb-4" variant="white" size="xl">
                    Nix is a tool that takes a unique approach to package
                    management and system configuration. Learn how to make
                    reproducible, declarative and reliable systems.
                </Paragraph>
                <div
                    class="flex flex-col justify-center gap-4 text-center md:flex-row lg:justify-start"
                >
                    <Button
                        href="/download"
                        color="white"
                        size="log-nopadding"
                        classList="flex-1 text-xl"
                        icon="mdi:download"
                    >
                        Download</Button
                    >
                    <Button
                        href="/learn"
                        color="white-borders"
                        size="log-nopadding"
                        icon="mdi:learn-outline"
                        classList="flex-1 text-xl bg">Get started</Button
                    >
                </div>
            </div>
            <div
                class="border-primary-white min-h-[300px] rounded-3xl border-[1rem] bg-[#121314] drop-shadow-md"
            >
                <Asciinema
                    src="/demos/cover.cast"
                    settings={{
                        cols: 84,
                        poster: 'npt:0:01:22',
                        markers: [
                            [11.5, 'Ad-Hoc development environments'],
                            [41.5, 'Declarative development environments'],
                            [85.0, 'Build docker image with Nix'],
                            [122.0, 'Build minimal docker image with Nix'],
                        ],
                    }}
                />
            </div>
        </Container>
    </Segment>
    <div
        class="inline-svg-landing-search-top bg-[39%_100%] bg-no-repeat md:bg-bottom"
    >
        <Container
            class="grid gap-8 pt-16 pb-48 md:grid-cols-3 md:gap-4"
            tag="ul"
        >
            {
                landingFeatures.map(async (feature) => {
                    const { Content } = await render(feature);
                    return (
                        <li class="list-none text-center">
                            <InlineSVG
                                src={feature.data.img}
                                class="mx-auto mb-6 h-32 w-auto"
                            />
                            <Headline
                                level={3}
                                tag="b"
                                variant="blue"
                                class="mb-2"
                                center
                            >
                                {feature.data.title}
                            </Headline>
                            <Paragraph size="md" variant="black" center>
                                <Content />
                            </Paragraph>
                        </li>
                    );
                })
            }
        </Container>
    </div>
    <div
        class="after:bg-divider relative after:bottom-0 after:left-0 after:-mt-48 after:-mb-16 after:block after:h-[30rem] after:w-full after:overflow-hidden after:bg-[url(/divider/landing_search_bottom.svg)] after:bg-cover after:bg-[60%_100%] after:bg-no-repeat"
    >
        <div class="bg-secondary-afghani-blue-95 pt-4">
            <Container
                class="flex w-full flex-col items-center justify-center gap-4 pt-8 pb-8"
            >
                <Headline level={2} center variant="blue" class="text-4xl">
                    Choose from over 120 000 Packages
                </Headline>
                <Paragraph size="xl" class="pb-3 md:w-5/8" center>
                    The Nix Packages collection (<a
                        class="text-secondary-afghani-blue! font-bold"
                        href="#">Nixpkgs</a
                    >) offers a large selection of packages for the Nix package
                    manager.
                </Paragraph>
                <NixosSearchInput collection="packages" withSubmit />
            </Container>
        </div>
    </div>
    <Segment variant="white">
        <Container>
            <Headline variant="blue" level={2} center class="pb-2">
                Examples
            </Headline>
            <div class="grid items-center gap-4 pb-8 md:grid-cols-2">
                {
                    demos.data.map((demo) => {
                        return (
                            <div class="flex flex-col items-start gap-2 overflow-hidden">
                                <Asciinema
                                    title={demo.title}
                                    class="w-full self-center md:self-start"
                                    src={demo.file}
                                    settings={{
                                        poster: 'npt:0:00:30',
                                    }}
                                />
                            </div>
                        );
                    })
                }
            </div>
        </Container>
    </Segment>
</Layout>
