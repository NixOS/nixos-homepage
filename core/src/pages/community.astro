];

const widerEcosystem = [
  {
    href: 'https://guix.gnu.org/',
    name: 'Guix',
  },
  {
    href: 'https://tvix.dev/',
    name: 'Tvix',
  },
  {
    href: 'https://lix.systems',
    name: 'Lix',
  },
  {
    href: 'https://docs.determinate.systems/determinate-nix',
