---
import { Icon } from 'astro-icon/components';

import Container from '@nixos/ui/Container.astro';
import Link from '@nixos/ui/Link.astro';
import { Image } from 'astro:assets';

interface Props {
  menu?: any;
  banner?: any;
  currentTopRoute?: string;
  logoUrl: ImageMetadata;
}
const { menu, banner, currentTopRoute, logoUrl } = Astro.props;

const navbarItemStyle = `text-center text-secondary-afghani-blue-45 md:text-primary-black md:hover:border-b-secondary-afghani-blue-65 border-b-4`;
const navbarItemInactiveStyle = `border-b-secondary-afghani-blue-95 md:border-b-transparent bg-secondary-afghani-blue-95 md:bg-transparent`;
const navbarItemActiveStyle = `border-b-secondary-afghani-blue-85 bg-secondary-afghani-blue-85 text-primary-white md:text-primary-black md:bg-transparent font-bold`;
---

<header
  class="text-primary-black bg-primary-white sticky top-0 z-50 font-light drop-shadow-md"
>
  {
    banner && (
      <a
        href={banner.sitewide.link.url}
        target="_blank"
        rel="noopener noreferrer"
        class:list={['block py-2 font-bold', banner.sitewide.wrapperClasses]}
      >
        <Container class:list={['flex items-center justify-between']}>
          <span class="line-clamp-1">{banner.sitewide.message}</span>
          <span class:list={['line-clamp-1 cursor-pointer underline']}>
            {banner.sitewide.link.text}
          </span>
        </Container>
      </a>
    )
  }
  <Container class="flex flex-col justify-between md:flex-row md:items-center">
    <div
      class="my-2 flex items-center justify-between gap-2 text-4xl font-normal md:justify-start"
    >
      <Link
        href="/"
        class="flex items-center justify-between gap-2 select-none md:justify-start"
      >
        <Image class="h-12 w-auto" src={logoUrl} alt="NixOS - Go to homepage" />
      </Link>

      <button
        aria-label="Main Navigation Toggle"
        aria-controls="navbar-menu"
        aria-expanded="true"
        class="bg-secondary-afghani-blue block rounded-lg p-4 md:hidden"
        id="navigation-toggle"
      >
        <span class="bg-primary-white mb-1.5 block h-1 w-8"></span>
        <span class="bg-primary-white mb-1.5 block h-1 w-8"></span>
        <span class="bg-primary-white block h-1 w-8"></span>
      </button>
    </div>

    <nav
      aria-label="Main Navigation"
      class="flex flex-col gap-0.5 pb-4 leading-none md:flex md:flex-row md:gap-5 md:pb-0"
      id="navbar-menu"
    >
      {
        menu.map((item) => (
          <Link
            class:list={[
              'pt-7 pb-6',
              navbarItemStyle,
              currentTopRoute === item.link
                ? navbarItemActiveStyle
                : navbarItemInactiveStyle,
            ]}
            aria-current={currentTopRoute === item.link ? 'page' : undefined}
            href={item.link}
          >
            {item.name}
          </Link>
        ))
      }
      <Link
        class={`pt-7 pb-6 md:pt-5 md:pb-3 ${navbarItemStyle} ${navbarItemInactiveStyle}`}
        href="https://search.nixos.org"
        aria-label="Nixos package and options search"
        target="_self"
      >
        <Icon
          class="text-secondary-afghani-blue hidden h-8 w-8 md:block"
          name="mdi:search"
        />
        <span class="inline-block md:hidden">Search</span>
      </Link>
    </nav>
  </Container>
</header>

<script>
  const navigationToggle = document.getElementById('navigation-toggle');
  const navbarMenu = document.getElementById('navbar-menu');

  function toggleMenu() {
    navigationToggle.ariaExpanded =
      navigationToggle.ariaExpanded === 'true' ? 'false' : 'true';
    navbarMenu.classList.toggle('hidden');
    navbarMenu.classList.toggle('flex');
  }
  toggleMenu();

  navigationToggle.addEventListener('click', () => toggleMenu());
</script>
