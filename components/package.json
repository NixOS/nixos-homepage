{
  "name": "@nixos/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Reusable Astro UI components NixOS frontend projects",
  "license": "ISC",
  "scripts": {
    "storybook": "storybook dev",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NixOS/nixos-homepage.git",
    "directory": "components"
  },
  "exports": {
    ".": "./index.ts",
    "./*.astro": "./src/*.astro",
    "./astroIntegration": "./astroIntegration.ts",
    "./tailwind": "./tailwind.config.cjs",
    "./package.json": "./package.json"
  },
  "files": [
    "index.ts",
    "astroIntegration.ts",
    "tailwind.config.cjs",
    "src"
  ],
  "dependencies": {
    "@nixos/branding": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "node-html-parser": "^9.0.0",
    "svgo": "^4.0.2",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.90"
  },
  "peerDependencies": {
    "@iconify/tailwind": "^1.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.1",
    "astro-icon": "^1.1.5",
    "tailwindcss": "^4.3.3"
  },
  "peerDependenciesMeta": {
    "@iconify/tailwind": {
      "optional": true
    },
    "@tailwindcss/vite": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook-astro/framework": "^1.9.0",
    "@storybook/builder-vite": "^10.5.4",
    "storybook": "^10.5.4"
  }
}
